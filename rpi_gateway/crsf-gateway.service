[Unit]
Description=CRSF to UDP gateway (RC bridge, ground side)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/crsf-link
ExecStart=/usr/bin/python3 -m rpi_gateway.crsf_reader --config /opt/crsf-link/rpi_gateway/config.yaml
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
